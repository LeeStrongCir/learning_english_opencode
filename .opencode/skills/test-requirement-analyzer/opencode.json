{
  "name": "test-requirement-analyzer",
  "version": "1.0.0",
  "description": "需求测试分析专家 - 自动分析软件需求文档的测试目标、范围、优先级和风险",
  "main": "index.js",
  "bin": {
    "test-requirement-analyzer": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "analyze": "node index.js --document"
  },
  "keywords": [
    "testing",
    "requirement-analysis",
    "qa",
    "test-planning",
    "opencode",
    "openclaw"
  ],
  "author": "臭宝 (Chou Bao)",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "opencode": {
    "commands": {
      "analyze-requirement": {
        "description": "分析需求文档的测试目标、范围、优先级",
        "usage": "/analyze-requirement <document-path>",
        "example": "/analyze-requirement ./requirements/v1.2.md"
      }
    },
    "integration": {
      "type": "skill",
      "compatible_with": ["openclaw", "opencode"],
      "requires": ["node>=18"]
    }
  }
}
