/* 对话页面样式 */
.dialogue-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-color);
}

/* 顶部情景信息栏 */
.scenario-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: var(--card-bg);
  border-bottom: 1rpx solid #EEEEEE;
}

.scenario-info {
  flex: 1;
}

.scenario-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.scenario-detail {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.progress-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.progress-text {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 600;
  margin-bottom: 8rpx;
}

.progress-bar {
  width: 160rpx;
  height: 12rpx;
  background: var(--bg-color);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-light), var(--primary-color));
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* 聊天消息列表 */
.message-list {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}

.message-item {
  display: flex;
  margin-bottom: 24rpx;
}

.message-ai {
  flex-direction: row;
}

.message-user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.message-ai .message-avatar {
  background: var(--ai-bubble);
  margin-right: 16rpx;
}

.message-user .message-avatar {
  background: var(--user-bubble);
  margin-left: 16rpx;
}

.message-bubble {
  max-width: 75%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  position: relative;
}

.bubble-ai {
  background: var(--ai-bubble);
  border-top-left-radius: 4rpx;
}

.bubble-user {
  background: var(--user-bubble);
  border-top-right-radius: 4rpx;
}

.message-text {
  font-size: 32rpx;
  color: var(--text-primary);
  line-height: 1.6;
  word-wrap: break-word;
}

.message-translation {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed rgba(0, 0, 0, 0.1);
}

.message-actions {
  margin-top: 12rpx;
}

.play-btn {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: rgba(76, 175, 80, 0.15);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--primary-color);
}

/* 思考中动画 */
.bubble-thinking {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.thinking-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--primary-color);
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out;
}

.dot:nth-child(1) {
  animation-delay: -0.32s;
}

.dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.thinking-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 底部操作区 */
.action-area {
  background: var(--card-bg);
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #EEEEEE;
}

/* 录音按钮 */
.record-section {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.record-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 180rpx;
  height: 180rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.35);
  transition: all 0.2s ease;
}

.record-btn:active,
.record-btn.recording {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.5);
  background: linear-gradient(135deg, var(--primary-dark), #2E7D32);
}

.record-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.record-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 录音脉冲动画 */
.record-btn.recording::before {
  content: '';
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--primary-color);
  opacity: 0.3;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 0.3;
  }
  100% {
    transform: scale(1.4);
    opacity: 0;
  }
}

/* 文字输入区 */
.input-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.text-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  background: var(--bg-color);
  border-radius: 40rpx;
  font-size: 30rpx;
}

.send-btn {
  padding: 0 32rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: var(--primary-color);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.send-btn[disabled] {
  background: #CCCCCC;
  color: #FFFFFF;
}

/* 结束对话按钮 */
.end-section {
  display: flex;
  justify-content: center;
}

.end-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: transparent;
  color: #FF5252;
  border: 2rpx solid #FF5252;
  border-radius: 36rpx;
  font-size: 28rpx;
}
