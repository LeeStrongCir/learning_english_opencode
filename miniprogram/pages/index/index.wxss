/* 首页样式 */
.header {
  text-align: center;
  padding: 40rpx 0 32rpx;
}

.header .title {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12rpx;
}

.header .subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 选择器卡片 */
.selector-card {
  margin-bottom: 20rpx;
}

.selector-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
}

.picker-text {
  font-size: 34rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.picker-arrow {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 单元列表区域 */
.units-section {
  margin-top: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

/* 单元卡片 */
.unit-card {
  position: relative;
  padding: 28rpx;
  margin-bottom: 20rpx;
  transition: all 0.2s ease;
  border-left: 6rpx solid var(--primary-color);
}

.unit-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

.unit-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.unit-number {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 600;
  background: var(--ai-bubble);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.unit-arrow {
  font-size: 32rpx;
  color: var(--primary-color);
}

.unit-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.unit-title-cn {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.unit-footer {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.scenario-tag {
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--bg-color);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 加载动画 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid var(--bg-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  color: var(--text-light);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}
