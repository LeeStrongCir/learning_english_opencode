/* 报告页面样式 */
.report-container {
  padding-bottom: 40rpx;
}

/* 总分展示区域 */
.score-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx;
  background: linear-gradient(135deg, var(--primary-light), var(--primary-color));
  color: #FFFFFF;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
}

.score-number {
  font-size: 72rpx;
  font-weight: bold;
  line-height: 1;
}

.score-label {
  font-size: 28rpx;
  margin-top: 8rpx;
  opacity: 0.9;
}

.encourage-text {
  font-size: 32rpx;
  text-align: center;
  line-height: 1.6;
  font-weight: 500;
}

/* 评分卡片 */
.score-card {
  padding: 28rpx;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.card-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.card-score {
  font-size: 30rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.score-good {
  background: var(--ai-bubble);
  color: var(--primary-color);
}

.score-need-improve {
  background: #FFF3E0;
  color: #FF9800;
}

/* 进度条 */
.score-bar {
  width: 100%;
  height: 16rpx;
  background: var(--bg-color);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.score-fill {
  height: 100%;
  background: var(--primary-color);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.card-detail {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  padding: 16rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
}

/* 词汇使用区域 */
.vocabulary-section {
  margin-bottom: 20rpx;
}

.vocab-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.vocab-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.vocab-item {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: var(--bg-color);
  border-radius: 24rpx;
}

.vocab-word {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-right: 12rpx;
  font-weight: 500;
}

.vocab-status {
  font-size: 24rpx;
}

.vocab-status.used {
  color: var(--primary-color);
}

.vocab-status.not-used {
  color: var(--text-light);
}

.vocab-rate {
  margin-top: 16rpx;
}

.vocab-rate-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

/* 优点/建议列表 */
.advices-card {
  padding: 28rpx;
}

.list-section {
  margin-top: 16rpx;
}

.list-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.list-item:last-child {
  border-bottom: none;
}

.item-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.item-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

.strength-item .item-text {
  color: var(--primary-dark);
}

.suggestion-item .item-text {
  color: #E65100;
}

/* 底部按钮 */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 24rpx;
  margin-top: 16rpx;
}

/* 加载动画 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid var(--bg-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
  color: var(--text-light);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}
