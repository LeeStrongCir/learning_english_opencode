# 阿里云登录自动化测试 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# 测试环境配置
BASE_URL=https://account.aliyun.com/login/login.htm

# 测试账号配置（使用测试环境账号，不要使用生产账号）
TEST_PHONE=13800138000
TEST_EMAIL=test@example.com
TEST_USERNAME=test_user_001
TEST_PASSWORD=TestPass123!

# 浏览器配置
BROWSER=chromium
HEADLESS=true
SLOW_MO=0

# 超时配置
PAGE_LOAD_TIMEOUT=30000
ELEMENT_WAIT_TIMEOUT=10000

# 日志配置
LOG_LEVEL=INFO
